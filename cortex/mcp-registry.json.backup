{
  "agi-memory": {
    "command": "python3",
    "args": [
      "/home/pilote/projet/agi/cortex/memory/stdio_wrapper.py"
    ],
    "transport": "stdio",
    "env": {
      "PYTHONPATH": "/home/pilote/projet/agi/backend",
      "DATABASE_URL": "postgresql://agi_user:mysecretpassword@localhost:5433/agi_db",
      "REDIS_URL": "redis://localhost:6380"
    },
    "tools": [
      "memory_search",
      "memory_store",
      "memory_stats"
    ],
    "category": "memory",
    "description": "AGI memory system with hybrid RAG"
  },
  "smithery-fetch": {
    "command": "npx",
    "args": [
      "-y",
      "@smithery/cli@latest",
      "run",
      "@smithery-ai/fetch",
      "--key",
      "0cccee52-3826-4658-8e05-b35aaf2627f1",
      "--profile",
      "rolling-ladybug-4DEfPv"
    ],
    "transport": "stdio",
    "tools": [
      "fetch_url",
      "extract_elements",
      "get_page_metadata"
    ],
    "category": "web",
    "description": "Web fetching and scraping with Smithery credentials"
  },

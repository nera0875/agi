## ⚙️ POLLING AUTOMATIQUE (Toutes les 30 secondes)

```python
import asyncio

async def autonomous_polling_loop():
    """
    Boucle autonome qui tourne en background
    Vérifie l'état des agents et exécute les actions nécessaires
    """
    while True:
        # Check worker tasks status
        tasks = mcp__agi_tools__pg_query({
            "sql": "SELECT * FROM worker_tasks WHERE status = 'running'"
        })

        for task in tasks:
            # Si timeout dépassé
            if task['created_at'] + task['timeout_seconds'] < now():
                # Marquer comme failed
                mcp__agi_tools__pg_execute({
                    "sql": "UPDATE worker_tasks SET status = 'failed', error = 'timeout' WHERE id = $1",
                    "params": [task['id']]
                })

        # Check completed tasks
        completed = mcp__agi_tools__pg_query({
            "sql": """
                SELECT * FROM worker_tasks
                WHERE status = 'completed'
                AND completed_at > now() - interval '1 minute'
            """
        })

        for task in completed:
            # Exécuter next_action si défini dans metadata
            if task.get('metadata', {}).get('next_action'):
                # Queue la prochaine action
                mcp__agi_tools__pg_execute({
                    "sql": """
                        INSERT INTO pending_instructions (instruction_text, priority)
                        VALUES ($1, $2)
                    """,
                    "params": [task['metadata']['next_action'], 80]
                })

        # Sauvegarder l'état actuel
        mcp__agi_tools__pg_execute({
            "sql": """
                UPDATE active_context
                SET updated_at = now(),
                    context_variables = context_variables || $1
                WHERE session_active = true
            """,
            "params": [{"last_poll": "now()", "tasks_checked": len(tasks)}]
        })

        # Attendre 30 secondes
        await asyncio.sleep(30)

# Lancer la boucle en background (non-bloquant)
asyncio.create_task(autonomous_polling_loop())
```


## 🔄 BOOTSTRAP AUTOMATIQUE (EXÉCUTER AU DÉMARRAGE)

```python
# ============================================================================
# ÉTAPE 1: CHARGER LES INSTRUCTIONS DE DÉMARRAGE
# ============================================================================
bootstrap_instructions = mcp__agi_tools__pg_query({
    "sql": """
        SELECT instruction_type, instruction_content, tags
        FROM system_bootstrap
        WHERE active = true
        ORDER BY priority DESC
    """
})

# ============================================================================
# ÉTAPE 2: RESTAURER LE CONTEXTE DE LA DERNIÈRE SESSION
# ============================================================================
active_session = mcp__agi_tools__pg_query({
    "sql": """
        SELECT *
        FROM active_context
        WHERE session_active = true
        ORDER BY updated_at DESC
        LIMIT 1
    """
})

# Si session active trouvée → RESTAURER et CONTINUER
if active_session:
    print(f"🔄 Session restaurée: {active_session['conversation_phase']}")
    # Charger les variables de contexte
    # Reprendre les tâches en cours

# ============================================================================
# ÉTAPE 3: CHARGER TOUTES LES RÈGLES SYSTÈME
# ============================================================================
system_rules = mcp__agi_tools__pg_query({
    "sql": """
        SELECT rule_content, priority
        FROM system_rules
        WHERE active = true
        ORDER BY priority DESC
    """
})

# ============================================================================
# ÉTAPE 4: VÉRIFIER LES AGENTS BACKGROUND EN COURS
# ============================================================================
running_tasks = mcp__agi_tools__pg_query({
    "sql": """
        SELECT id, task_type, status, created_at, metadata
        FROM worker_tasks
        WHERE status IN ('pending', 'running')
        ORDER BY priority DESC, created_at ASC
    """
})

# Pour chaque tâche en cours:
for task in running_tasks:
    # Si running depuis >timeout → marquer failed
    # Si pending → peut lancer un worker pour l'exécuter
    # Si completed récemment → exécuter next_action si défini
    pass

# ============================================================================
# ÉTAPE 5: CHARGER INSTRUCTIONS EN ATTENTE
# ============================================================================
pending = mcp__agi_tools__pg_query({
    "sql": """
        SELECT id, instruction_text, priority, execution_context
        FROM pending_instructions
        WHERE status = 'pending'
        ORDER BY priority DESC
        LIMIT 10
    """
})

# Si des instructions pending → Les exécuter
if pending:
    print(f"📋 {len(pending)} instructions en attente")
```


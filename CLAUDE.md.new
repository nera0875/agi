## 📝 SAUVEGARDER LE CONTEXTE APRÈS CHAQUE ACTION

```python
# Après CHAQUE action importante
mcp__agi_tools__pg_execute({
    "sql": """
        INSERT INTO active_context (
            session_id,
            conversation_phase,
            context_variables,
            last_agent_action
        ) VALUES (
            $1, $2, $3, $4
        )
        ON CONFLICT (session_id)
        DO UPDATE SET
            conversation_phase = EXCLUDED.conversation_phase,
            context_variables = active_context.context_variables || EXCLUDED.context_variables,
            last_agent_action = EXCLUDED.last_agent_action,
            updated_at = now()
    """,
    "params": [
        "current-session-id",  # UUID unique de la session
        "working",              # Phase actuelle
        {                       # Variables de contexte
            "current_table": "agi_knowledge",
            "resize_columns": true,
            "last_action": "fixed_column_resize"
        },
        "Fixed table-layout for column resize"
    ]
})
```


# AGI Memory System - API Keys Configuration
# Copy to .env and fill with your actual keys

# ═══════════════════════════════════════════════════════
# AI PROVIDERS
# ═══════════════════════════════════════════════════════

# OpenAI (GPT-5, o3, o3-deep-research)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (3.5 Haiku/Sonnet, 3 Opus)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cohere (Rerank v3.5, Classify)
COHERE_API_KEY=your_cohere_api_key_here

# Voyage AI (Code-2, v3-large, Rerank-2)
VOYAGE_API_KEY=your_voyage_api_key_here

# ═══════════════════════════════════════════════════════
# LANGCHAIN / LANGSMITH
# ═══════════════════════════════════════════════════════

# LangSmith (optional but recommended for debugging)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=agi-memory-system
LANGSMITH_TRACING=true

# ═══════════════════════════════════════════════════════
# DATABASES
# ═══════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agi_db
POSTGRES_USER=agi_user
POSTGRES_PASSWORD=agi_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Voiture789

# ═══════════════════════════════════════════════════════
# MCP SERVERS (Already configured in your system)
# ═══════════════════════════════════════════════════════

# Exa, Docfork, Fetch are already available via MCP
# No additional configuration needed

# ═══════════════════════════════════════════════════════
# SYSTEM CONFIGURATION
# ═══════════════════════════════════════════════════════

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# Performance
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30

# Cost tracking
ENABLE_COST_TRACKING=true

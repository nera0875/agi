{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(pip3 install:*)",
      "Bash(sudo -u postgres psql:*)",
      "Bash(sudo -S -u postgres psql:*)",
      "Bash(sudo -S -u postgres createdb:*)",
      "Bash(sudo -S -u postgres dropdb:*)",
      "Bash(source ~/.bashrc)",
      "Read(//home/pilote/.opencode/bin/**)",
      "Bash(~/.opencode/bin/opencode:*)",
      "WebSearch",
      "Bash(env)",
      "Read(//home/pilote/.claude/**)",
      "Read(//home/pilote/**)",
      "Bash(claude mcp list:*)",
      "mcp__smithery-ai-fetch__fetch_url",
      "mcp__smithery-ai-fetch__extract_elements",
      "Read(//tmp/**)",
      "Bash(cat:*)",
      "Bash(PGPASSWORD=agi_password psql:*)",
      "Bash(PGPASSWORD=mysecretpassword psql:*)",
      "Bash(wget:*)",
      "Bash(tar:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(./ts3server_startscript.sh:*)",
      "Bash(awk:*)",
      "mcp__agi-tools__pg_query",
      "mcp__agi-tools__memory_search",
      "mcp__agi-tools__list_my_mcps",
      "mcp__agi-tools__discover_mcp",
      "mcp__agi-tools__use_mcp",
      "mcp__agi-tools__pg_schema"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "agi-memory",
    "mcp-router",
    "smithery-ai-fetch",
    "exa",
    "agi-tools"
  ],
  "hooks": {
    "user-prompt-submit": [
      {
        "type": "command",
        "command": "python3 /home/pilote/projet/agi/cortex/hooks/capture_user_message.py \"$CLAUDE_USER_PROMPT\""
      }
    ],
    "post-tool-use": [
      {
        "matcher": "mcp__exa__web_search_exa",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/pilote/projet/agi/cortex/hooks/store_tool_learning.py \"exa\" '$TOOL_RESULT'"
          }
        ]
      },
      {
        "matcher": "mcp__upstash-context-7-mcp__get-library-docs",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/pilote/projet/agi/cortex/hooks/store_tool_learning.py \"context7\" '$TOOL_RESULT'"
          }
        ]
      },
      {
        "matcher": "mcp__agi-tools__database",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/pilote/projet/agi/cortex/hooks/store_tool_learning.py \"database\" '$TOOL_RESULT'"
          }
        ]
      },
      {
        "matcher": "mcp__agi-tools__memory",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/pilote/projet/agi/cortex/hooks/store_tool_learning.py \"memory\" '$TOOL_RESULT'"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/pilote/projet/agi/cortex/hooks/log_neo4j_event.py \"$TOOL_NAME\" \"\" \"$CLAUDE_SESSION_ID\""
          }
        ]
      }
    ],
    "pre-compact": [
      {
        "type": "command",
        "command": "python3 /home/pilote/projet/agi/cortex/hooks/pre_compact_consolidation.py",
        "description": "Quick memory consolidation before context compact"
      },
      {
        "type": "command",
        "command": "python3 /home/pilote/projet/agi/cortex/hooks/consolidate_conversation.py '$CONVERSATION'"
      }
    ]
  }
}
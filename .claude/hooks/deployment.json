{
  "deployment": {
    "name": "AutoTriggerAgentHook",
    "version": "1.0",
    "created": "2025-10-20",
    "status": "operational",
    "type": "PostToolUseHook"
  },
  "files": {
    "core": {
      "auto_trigger_agent.py": {
        "size": "4.7 KB",
        "executable": true,
        "purpose": "Main hook - triggers agents on critical file edits",
        "entry_point": "main()"
      }
    },
    "tools": {
      "monitor_triggers.py": {
        "size": "4.5 KB",
        "executable": true,
        "purpose": "Monitor and analyze trigger statistics",
        "cli": "python3 monitor_triggers.py [--stats|--timeline|--follow|--clear]"
      },
      "test_hook.sh": {
        "size": "1.8 KB",
        "executable": true,
        "purpose": "Comprehensive test suite",
        "cli": "bash test_hook.sh"
      }
    },
    "documentation": {
      "README.md": "Quick start and overview",
      "USAGE.md": "How to use the hook",
      "TECHNICAL.md": "Deep dive architecture",
      "INDEX.md": "Documentation index",
      "deployment.json": "This deployment manifest"
    },
    "logs": {
      ".trigger_log": {
        "type": "JSON lines",
        "format": "one JSON object per line",
        "size": "grows ~200 bytes per trigger"
      }
    }
  },
  "configuration": {
    "settings_file": ".claude/settings.json",
    "section": "hooks.post-tool-use",
    "hook_name": "auto-trigger-agents",
    "matcher": "Edit:backend/**/*|Write:backend/**/*|Edit:cortex/**/*|Write:cortex/**/*|Edit:CLAUDE.md|Write:CLAUDE.md|Edit:frontend/src/**|Write:frontend/src/**",
    "timeout_seconds": 2
  },
  "trigger_rules": {
    "total": 8,
    "rules": [
      {
        "pattern": "backend/api/schema.py",
        "agent": "debug",
        "reason": "GraphQL schema validation"
      },
      {
        "pattern": "backend/services/memory_service.py",
        "agent": "performance_optimizer",
        "reason": "Memory service performance"
      },
      {
        "pattern": "backend/services/graph_service.py",
        "agent": "debug",
        "reason": "Neo4j graph operations"
      },
      {
        "pattern": "backend/services/voyage_wrapper.py",
        "agent": "performance_optimizer",
        "reason": "Embeddings API cost optimization"
      },
      {
        "pattern": "cortex/agi_tools_mcp.py",
        "agent": "debug",
        "reason": "MCP tools validation"
      },
      {
        "pattern": "backend/agents/",
        "agent": "debug",
        "reason": "Agent implementation testing"
      },
      {
        "pattern": "CLAUDE.md",
        "agent": "docs",
        "reason": "Documentation consistency"
      },
      {
        "pattern": "frontend/src/",
        "agent": "frontend",
        "reason": "TypeScript build validation"
      }
    ]
  },
  "performance": {
    "hook_execution_ms": 200,
    "pattern_matching_ms": 10,
    "subprocess_spawn_ms": 100,
    "total_ms": 200,
    "impact_on_workflow": "zero"
  },
  "features": {
    "non_blocking": true,
    "automatic": true,
    "safe": true,
    "parallel": true,
    "extensible": true,
    "observable": true,
    "production_ready": true
  },
  "testing": {
    "unit_tests": "bash test_hook.sh",
    "test_coverage": [
      "Hook file exists and executable",
      "Python syntax validation",
      "Edit/Write operations",
      "Trigger rule coverage",
      "Manual invocation"
    ],
    "test_status": "passing"
  },
  "monitoring": {
    "command": "python3 monitor_triggers.py",
    "options": [
      "--stats",
      "--timeline HOURS",
      "--follow",
      "--clear"
    ],
    "log_file": ".trigger_log",
    "log_format": "JSON lines"
  },
  "safety": {
    "permissions": "same as Claude Code",
    "privilege_escalation": false,
    "shell_injection": false,
    "exception_handling": "silent fail"
  },
  "extensibility": {
    "add_rule": "Edit TRIGGER_RULES dict in auto_trigger_agent.py",
    "change_rule": "Modify existing TRIGGER_RULES entry",
    "disable_rule": "Comment out in TRIGGER_RULES",
    "test_change": "bash test_hook.sh"
  },
  "supported_agents": [
    "ask",
    "research",
    "architect",
    "code",
    "frontend",
    "debug",
    "docs",
    "sre"
  ],
  "requirements": {
    "python": "3.7+",
    "subprocess": "standard library",
    "json": "standard library",
    "pathlib": "standard library"
  },
  "deployment_checklist": {
    "files_created": true,
    "settings_configured": true,
    "tests_passing": true,
    "documentation_complete": true,
    "monitoring_ready": true,
    "ready_for_production": true
  },
  "deployment_notes": {
    "1_activation": "Hook is automatically active via settings.json",
    "2_first_use": "Edit any critical file, agent triggers in background",
    "3_monitoring": "Run: python3 monitor_triggers.py",
    "4_customization": "Edit TRIGGER_RULES dict in auto_trigger_agent.py",
    "5_testing": "Run: bash test_hook.sh"
  },
  "quick_commands": {
    "test": "bash .claude/hooks/test_hook.sh",
    "monitor": "python3 .claude/hooks/monitor_triggers.py",
    "follow": "python3 .claude/hooks/monitor_triggers.py --follow",
    "view_logs": "tail -f .claude/hooks/.trigger_log",
    "clear_logs": "python3 .claude/hooks/monitor_triggers.py --clear",
    "test_manual": "export CLAUDE_TOOL_NAME=Edit CLAUDE_FILE_PATH=backend/api/schema.py; python3 .claude/hooks/auto_trigger_agent.py"
  },
  "support": {
    "documentation": ".claude/hooks/INDEX.md",
    "troubleshooting": ".claude/hooks/TECHNICAL.md",

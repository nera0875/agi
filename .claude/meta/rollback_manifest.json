  "modes": {
    "soft": {
      "name": "Soft Rollback",
      "description": "Preserve changes, undo commit",
      "use_case": "agent_fail",
      "creates_backup": false,
      "loses_changes": false,
      "risk": "low"
    },
    "hard": {
      "name": "Hard Rollback",
      "description": "Discard changes, create backup branch",
      "use_case": "test_fail",
      "creates_backup": true,
      "loses_changes": true,
      "risk": "medium"
    },
    "branch": {
      "name": "Branch Rollback",
      "description": "Restore from safety backup",
      "use_case": "critical_error",
      "creates_backup": true,
      "loses_changes": true,
      "risk": "low"
    }
  },
  "logging": {
    "location": ".claude/meta/rollback.log",
    "format": "TIMESTAMP | MODE | ERROR_TYPE | DETAILS",
    "retention": "unlimited",
    "example": "2025-10-20 16:30:45 | SOFT | agent_fail:code | From: abc1234 | Changes preserved"
  },
